DATABASE_URL="postgresql://s2amanager:password@127.0.0.1:5432/s2amanager?schema=public"
APP_SECRET="change-me-to-a-24-plus-char-secret!"
ENCRYPTION_KEY="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
# 默认 false，允许 dev/prod 通过 HTTP 访问。仅在 HTTPS-only 部署时设为 true。
S2A_SESSION_COOKIE_SECURE=false
# Web 服务监听端口，默认 15074。
# 注意：Next.js 不会从 .env 文件读取 PORT，需要作为进程级环境变量传入
# （Docker / docker-compose / systemd / shell：PORT=15074 npm run start）。
PORT=15074
